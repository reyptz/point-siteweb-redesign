---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recherche & Enregistrement de domaine .ml - Point.ml" description="Recherchez et réservez votre nom de domaine souverain en .ml gratuitement (pour 4 caractères ou plus) ou en formule premium.">
  <main id="main-content">
    
    <!-- HERO SECTION WITH SEARCH ENGINE -->
    <section class="hero-section" style="background-color: var(--color-primary); color: var(--color-white); padding: 80px 0; border-bottom: 4px solid var(--color-secondary);">
      <div class="container" style="text-align: center; max-width: 800px; margin: 0 auto;">
        <span class="badge badge-info" style="margin-bottom: 16px; background-color: rgba(255,255,255,0.15); color: var(--color-white);">Enregistrement officiel ccTLD .ML</span>
        <h1 style="color: var(--color-white); margin-bottom: 16px;">Trouvez votre identité numérique malienne</h1>
        <p style="color: rgba(255,255,255,0.8); font-size: 1.1rem; margin-bottom: 32px;">
          Enregistrez votre nom de domaine en .ml gratuitement ou accédez à nos formules premium pour renforcer votre présence sur Internet.
        </p>

        <!-- Search Bar -->
        <div style="background-color: var(--color-white); padding: 8px; border-radius: var(--radius-md); display: flex; gap: 8px; box-shadow: var(--shadow-lg);">
          <input type="text" id="domainInput" placeholder="Rechercher un nom de domaine (ex: mon-administration)" style="flex-grow: 1; border: none; padding: 12px 16px; font-size: 1.1rem; outline: none; color: var(--color-dark);" />
          <span style="display: flex; align-items: center; font-size: 1.2rem; font-weight: 700; color: var(--color-text-muted); padding-right: 12px;">.ml</span>
          <button id="searchBtn" class="btn btn-primary" style="font-size: 1.1rem; padding: 0 32px;">Rechercher</button>
        </div>

        <!-- Result Box (Simulated via script) -->
        <div id="resultBox" style="display: none; margin-top: 24px; padding: 24px; border-radius: var(--radius-md); text-align: left; background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
          <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
            <div>
              <h3 id="resultDomainName" style="color: var(--color-white); margin-bottom: 4px;"></h3>
              <p id="resultStatus" style="font-size: 0.95rem; color: rgba(255,255,255,0.7);"></p>
            </div>
            <div>
              <span id="resultPrice" style="font-size: 1.4rem; font-weight: 700; color: var(--color-secondary); margin-right: 16px;"></span>
              <button id="actionBtn" class="btn btn-secondary">Enregistrer</button>
            </div>
          </div>
        </div>
        
        <!-- Cart Message -->
        <div id="cartMessage" style="display: none; margin-top: 16px; padding: 12px; background-color: rgba(17, 169, 59, 0.15); border: 1px solid var(--color-success); border-radius: var(--radius-sm); color: #8ce8a3; text-align: left;">
          Domaine ajouté à vos réservations temporaires. <a href="/connexion?redirect=register" style="color: var(--color-white); text-decoration: underline; font-weight: 700;">Connectez-vous pour finaliser l'enregistrement</a>.
        </div>
      </div>
    </section>

    <!-- SECTION REGLES & PRICING -->
    <section class="section" id="regles" style="background-color: var(--color-white);">
      <div class="container">
        <div style="text-align: center; max-width: 700px; margin: 0 auto 50px;">
          <h2>Tarifs et Règles d'Enregistrement</h2>
          <p style="color: var(--color-text-muted);">
            L'extension nationale du Mali (.ml) propose une charte de nommage hybride conçue pour favoriser la présence numérique locale et la souveraineté.
          </p>
        </div>

        <div class="grid-2">
          <div class="card" style="border-left: 4px solid var(--color-success);">
            <h3 style="color: var(--color-success); margin-bottom: 12px;">Domaines Gratuits (.ml)</h3>
            <p style="font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: 16px; line-height: 1.6;">
              Idéal pour les entreprises locales, les associations, et les projets personnels.
            </p>
            <ul style="display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem; color: var(--color-text); margin-bottom: 24px;">
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Longueur de 4 caractères ou plus</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Enregistrement de 1 à 12 mois</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Renouvellement gratuit et illimité</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Configuration DNS & Redirection complète</li>
            </ul>
            <div style="font-size: 1.25rem; font-weight: 700; color: var(--color-primary-dark);">0 FCFA <span style="font-size: 0.85rem; color: var(--color-text-muted); font-weight: 400;">/ an</span></div>
          </div>

          <div class="card" style="border-left: 4px solid var(--color-secondary);">
            <h3 style="color: var(--color-secondary-dark); margin-bottom: 12px;">Domaines Premiums & Courts</h3>
            <p style="font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: 16px; line-height: 1.6;">
              Recommandé pour les marques internationales, les noms courts, et les mots clés génériques.
            </p>
            <ul style="display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem; color: var(--color-text); margin-bottom: 24px;">
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-secondary-dark); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Longueur de 1 à 3 caractères</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-secondary-dark); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Enregistrement jusqu'à 10 ans</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-secondary-dark); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Protection renforcée contre le cybersquattage</li>
              <li style="display: flex; gap: 8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-secondary-dark); flex-shrink: 0;"><polyline points="20 6 9 17 4 12"></polyline></svg> Facturation annuelle classique</li>
            </ul>
            <div style="font-size: 1.25rem; font-weight: 700; color: var(--color-primary-dark);">Dès 15 000 FCFA <span style="font-size: 0.85rem; color: var(--color-text-muted); font-weight: 400;">/ an</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION INFOS SOUVERAINETÉ -->
    <section class="section section-alt">
      <div class="container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
        <div>
          <h2>Un Espace Numérique National et Souverain</h2>
          <p style="color: var(--color-text-muted); margin-bottom: 16px; line-height: 1.7;">
            Le registre du domaine .ml est hébergé au Mali, sur des serveurs administrés par l'AGETIC et surveillés 24/7. En enregistrant un domaine .ml, vous renforcez l'identité numérique de la République du Mali et contribuez au développement de l'écosystème web national.
          </p>
          <p style="color: var(--color-text-muted); margin-bottom: 24px; line-height: 1.7;">
            Notre infrastructure robuste garantit une résolution de requêtes DNS à latence minimale dans toute la sous-région et une conformité rigoureuse avec les standards IANA/ICANN.
          </p>
          <a href="/contact" class="btn btn-primary">Contacter le service technique</a>
        </div>
        <div style="background-color: var(--color-light); border: 1px solid var(--color-border); padding: 32px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
          <h3 style="color: var(--color-primary-dark); margin-bottom: 16px;">Statistiques du Registre</h3>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">
              <span style="font-weight: 600;">Disponibilité DNS Racine</span>
              <span style="color: var(--color-success); font-weight: 700;">99.999%</span>
            </div>
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">
              <span style="font-weight: 600;">Nombre de serveurs Anycast</span>
              <span>4 zones</span>
            </div>
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">
              <span style="font-weight: 600;">Temps moyen de propagation</span>
              <span>&lt; 15 minutes</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
              <span style="font-weight: 600;">Autorité délégataire</span>
              <span>AGETIC Mali</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  // DOM Elements
  const domainInput = document.getElementById('domainInput') as HTMLInputElement;
  const searchBtn = document.getElementById('searchBtn');
  const resultBox = document.getElementById('resultBox');
  const resultDomainName = document.getElementById('resultDomainName');
  const resultStatus = document.getElementById('resultStatus');
  const resultPrice = document.getElementById('resultPrice');
  const actionBtn = document.getElementById('actionBtn');
  const cartMessage = document.getElementById('cartMessage');

  // Simulated Registry check
  if (searchBtn && domainInput && resultBox && resultDomainName && resultStatus && resultPrice && actionBtn) {
    searchBtn.addEventListener('click', () => {
      let rawVal = domainInput.value.trim().toLowerCase();
      if (!rawVal) return;

      // Clean domain name
      rawVal = rawVal.replace(/\.ml$/, '').replace(/[^a-z0-9-]/g, '');
      if (rawVal.length === 0) {
        alert("Veuillez saisir un nom de domaine valide (lettres, chiffres et tirets uniquement).");
        return;
      }

      const domainName = rawVal + ".ml";
      
      // Calculate length and keywords for price simulation
      const reservedKeywords = ["google", "facebook", "bank", "mali", "agetic", "amrtp", "smtd", "gouv", "admin", "courrier"];
      let isReserved = reservedKeywords.some(k => rawVal.includes(k));
      let isPremium = rawVal.length <= 3;

      resultDomainName.textContent = domainName;
      resultBox.style.display = 'block';
      if (cartMessage) cartMessage.style.display = 'none';

      // Check if already registered in localStorage simulation
      const existingDomains = getRegisteredDomainsGlobal();
      const isAlreadyRegistered = existingDomains.includes(domainName);

      if (isAlreadyRegistered) {
        resultStatus.textContent = "Ce domaine est déjà enregistré.";
        resultPrice.textContent = "";
        actionBtn.style.display = 'none';
      } else if (isReserved) {
        resultStatus.textContent = "Ce domaine est réservé par l'État du Mali ou fait l'objet d'une protection de marque.";
        resultPrice.textContent = "Réservé";
        actionBtn.style.display = 'none';
      } else if (isPremium) {
        resultStatus.textContent = "Domaine Premium disponible.";
        resultPrice.textContent = "15 000 FCFA / an";
        actionBtn.style.display = 'inline-flex';
        actionBtn.textContent = "Enregistrer";
        actionBtn.onclick = () => addToCart(domainName, "15 000 FCFA");
      } else {
        resultStatus.textContent = "Domaine disponible à l'enregistrement.";
        resultPrice.textContent = "Gratuit";
        actionBtn.style.display = 'inline-flex';
        actionBtn.textContent = "Enregistrer (Gratuit)";
        actionBtn.onclick = () => addToCart(domainName, "Gratuit");
      }
    });
  }

  function getRegisteredDomainsGlobal() {
    // Collect all registered domains from all users in simulation
    const allUsersStr = localStorage.getItem('point_users') || '[]';
    const allUsers = JSON.parse(allUsersStr);
    let domains: string[] = [];
    allUsers.forEach((u: any) => {
      if (u.domains) {
        domains = domains.concat(u.domains.map((d: any) => d.name));
      }
    });
    return domains;
  }

  function addToCart(domainName: string, price: string) {
    // Check if session exists
    const sessionStr = localStorage.getItem('point_session');
    
    if (sessionStr) {
      // Direct registration for simulation
      const session = JSON.parse(sessionStr);
      const allUsersStr = localStorage.getItem('point_users') || '[]';
      const allUsers = JSON.parse(allUsersStr);
      
      const userIndex = allUsers.findIndex((u: any) => u.email === session.email);
      if (userIndex !== -1) {
        if (!allUsers[userIndex].domains) {
          allUsers[userIndex].domains = [];
        }
        
        // Add domain
        const newDomain = {
          name: domainName,
          registeredAt: new Date().toLocaleDateString('fr-FR'),
          expiresAt: new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toLocaleDateString('fr-FR'),
          price: price,
          ns: ["ns1.point.ml", "ns2.point.ml"],
          records: [
            { type: "A", name: "@", value: "197.218.0.1", ttl: "3600" },
            { type: "MX", name: "@", value: "10 mail.collab.gouv.ml", ttl: "3600" }
          ],
          redirection: { active: false, url: "" }
        };

        allUsers[userIndex].domains.push(newDomain);
        localStorage.setItem('point_users', JSON.stringify(allUsers));

        // Call SMTP simulation endpoint
        fetch('/api/register-domain', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: session.email, domainName: domainName })
        }).catch(err => console.log("Fetch simulation error: ", err));

        alert(`Félicitations ! Le nom de domaine ${domainName} a été enregistré avec succès et configuré dans votre dashboard.`);
        window.location.href = '/dashboard';
      }
    } else {
      // Save domain to temporary storage and display cart login message
      localStorage.setItem('point_temp_domain', JSON.stringify({ name: domainName, price: price }));
      if (cartMessage) cartMessage.style.display = 'block';
    }
  }
</script>
