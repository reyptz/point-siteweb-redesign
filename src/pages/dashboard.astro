---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mon Tableau de Bord DNS - Point.ml" description="Gérez vos noms de domaine .ml, configurez vos zones DNS (A, CNAME, MX), gérez vos serveurs NS et vos redirections web.">
  <main id="main-content" style="background-color: #F8FAFC;">
    
    <div class="page-intro">
      <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
        <div>
          <nav class="breadcrumbs" aria-label="Fil d'Ariane">
            <a href="/">Accueil</a> &gt; <span>Dashboard</span>
          </nav>
          <h1>Tableau de Bord DNS</h1>
        </div>
        <div>
          <a href="/#rechercher" class="btn btn-primary">Enregistrer un domaine</a>
        </div>
      </div>
    </div>

    <!-- Main Dashboard Section -->
    <section class="section" style="padding-top: 10px;">
      <div class="container" id="dashboardLoading">
        <p>Chargement de vos données en cours...</p>
      </div>

      <div class="container" id="dashboardContent" style="display: none;">
        <!-- Left Panel: Domain List -->
        <div style="display: grid; grid-template-columns: 300px 1fr; gap: 32px; align-items: start;" id="mainDashboardLayout">
          
          <!-- Column 1: Domains list -->
          <div style="background-color: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 20px; box-shadow: var(--shadow-sm);">
            <h3 style="font-size: 1.1rem; margin-bottom: 16px; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">Mes Domaines (.ml)</h3>
            <ul id="domainListUl" style="display: flex; flex-direction: column; gap: 8px;">
              <!-- Simulated list -->
            </ul>
            <div id="noDomainsMsg" style="display: none; text-align: center; padding: 20px 0; color: var(--color-text-muted);">
              <p style="font-size: 0.9rem; margin-bottom: 12px;">Aucun domaine enregistré.</p>
              <a href="/" class="btn btn-outline btn-sm">Rechercher</a>
            </div>
          </div>

          <!-- Column 2: Management Panel (Visible when a domain is selected) -->
          <div id="mgmtPanel" style="display: none; background-color: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 28px; box-shadow: var(--shadow-sm);">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--color-border); padding-bottom: 16px; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
              <div>
                <h2 id="mgmtDomainName" style="color: var(--color-primary); margin-bottom: 4px; font-size: 1.6rem;"></h2>
                <p style="font-size: 0.85rem; color: var(--color-text-muted);">
                  Enregistré le : <span id="mgmtRegDate" style="font-weight: 600; color: var(--color-text);"></span> | Expire le : <span id="mgmtExpDate" style="font-weight: 600; color: var(--color-text);"></span>
                </p>
              </div>
              <div>
                <span id="mgmtPriceBadge" class="badge badge-info"></span>
              </div>
            </div>

            <!-- Tab Buttons -->
            <div style="display: flex; gap: 8px; border-bottom: 1px solid var(--color-border); margin-bottom: 24px; padding-bottom: 1px; flex-wrap: wrap;">
              <button class="tab-btn active" id="tabDnsBtn" style="padding: 10px 16px; font-weight: 600; border: none; background: transparent; border-bottom: 3px solid var(--color-accent); cursor: pointer; color: var(--color-accent);">Zone DNS</button>
              <button class="tab-btn" id="tabNsBtn" style="padding: 10px 16px; font-weight: 600; border: none; background: transparent; cursor: pointer; color: var(--color-text-muted);">Serveurs de Noms (NS)</button>
              <button class="tab-btn" id="tabRedirBtn" style="padding: 10px 16px; font-weight: 600; border: none; background: transparent; cursor: pointer; color: var(--color-text-muted);">Redirection Web</button>
              <button class="tab-btn" id="tabActionsBtn" style="padding: 10px 16px; font-weight: 600; border: none; background: transparent; cursor: pointer; color: var(--color-text-muted);">Administration</button>
            </div>

            <!-- Tab 1: DNS Records -->
            <div class="tab-content" id="dnsTabContent">
              <h3 style="margin-bottom: 16px; font-size: 1.2rem;">Configuration des Enregistrements DNS</h3>
              
              <!-- Records Table -->
              <div class="table-responsive" style="margin-bottom: 24px;">
                <table>
                  <thead>
                    <tr>
                      <th>Type</th>
                      <th>Sous-domaine (Nom)</th>
                      <th>Destination (Valeur)</th>
                      <th>TTL</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody id="dnsRecordsTbody">
                    <!-- Loaded dynamically -->
                  </tbody>
                </table>
              </div>

              <!-- Add Record Form -->
              <h4 style="margin-bottom: 12px; font-size: 1rem;">Ajouter un enregistrement</h4>
              <form id="addDnsRecordForm" style="display: grid; grid-template-columns: 100px 1.5fr 2fr 100px auto; gap: 12px; align-items: end; background-color: var(--color-light); padding: 16px; border-radius: var(--radius-sm); border: 1px solid var(--color-border);">
                <div>
                  <label for="dnsType" class="form-label">Type</label>
                  <select id="dnsType" class="form-control" required>
                    <option value="A">A</option>
                    <option value="CNAME">CNAME</option>
                    <option value="MX">MX</option>
                    <option value="TXT">TXT</option>
                  </select>
                </div>
                <div>
                  <label for="dnsName" class="form-label">Nom</label>
                  <input type="text" id="dnsName" class="form-control" placeholder="@ ou sub" required />
                </div>
                <div>
                  <label for="dnsValue" class="form-label">Valeur</label>
                  <input type="text" id="dnsValue" class="form-control" placeholder="197.218.0.1 ou fqdn" required />
                </div>
                <div>
                  <label for="dnsTtl" class="form-label">TTL</label>
                  <input type="number" id="dnsTtl" class="form-control" value="3600" required />
                </div>
                <button type="submit" class="btn btn-primary">Ajouter</button>
              </form>
            </div>

            <!-- Tab 2: Nameservers -->
            <div class="tab-content" id="nsTabContent" style="display: none;">
              <h3 style="margin-bottom: 16px; font-size: 1.2rem;">Serveurs de Noms de Délégation (NS)</h3>
              <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 20px;">
                Configurez les serveurs de noms faisant autorité si vous gérez votre zone DNS chez un hébergeur tiers.
              </p>
              <form id="nsForm" style="max-width: 500px; display: flex; flex-direction: column; gap: 16px;">
                <div class="form-group">
                  <label for="ns1Input" class="form-label">Serveur de noms primaire *</label>
                  <input type="text" id="ns1Input" class="form-control" required />
                </div>
                <div class="form-group">
                  <label for="ns2Input" class="form-label">Serveur de noms secondaire *</label>
                  <input type="text" id="ns2Input" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Enregistrer les NS</button>
              </form>
              <div id="nsSuccess" style="display: none; margin-top: 12px; padding: 12px; background-color: rgba(17,169,59,0.15); border-left: 4px solid var(--color-success); border-radius: var(--radius-sm); color: #0b5e20;">
                Les serveurs de noms ont été mis à jour dans la zone racine du .ml. La propagation peut prendre jusqu'à 15 minutes.
              </div>
            </div>

            <!-- Tab 3: Web Redirection -->
            <div class="tab-content" id="redirTabContent" style="display: none;">
              <h3 style="margin-bottom: 16px; font-size: 1.2rem;">Redirection Web (Forwarding)</h3>
              <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 20px;">
                Redirigez automatiquement les visiteurs tapant votre nom de domaine vers une autre adresse internet existante.
              </p>
              <form id="redirForm" style="max-width: 500px; display: flex; flex-direction: column; gap: 16px;">
                <div class="form-group" style="display: flex; gap: 8px; align-items: center;">
                  <input type="checkbox" id="redirActive" style="transform: scale(1.2);" />
                  <label for="redirActive" style="font-weight: 600;">Activer la redirection web</label>
                </div>
                <div class="form-group" id="redirUrlGroup">
                  <label for="redirUrl" class="form-label">URL de destination *</label>
                  <input type="url" id="redirUrl" class="form-control" placeholder="https://mon-autre-site.com" />
                </div>
                <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Enregistrer la redirection</button>
              </form>
              <div id="redirSuccess" style="display: none; margin-top: 12px; padding: 12px; background-color: rgba(17,169,59,0.15); border-left: 4px solid var(--color-success); border-radius: var(--radius-sm); color: #0b5e20;">
                La redirection web a été configurée avec succès.
              </div>
            </div>

            <!-- Tab 4: Administration -->
            <div class="tab-content" id="actionsTabContent" style="display: none;">
              <h3 style="margin-bottom: 16px; font-size: 1.2rem;">Administration et Maintenance</h3>
              <div style="border: 1px solid var(--color-border); padding: 24px; border-radius: var(--radius-sm); margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                <div>
                  <h4 style="margin-bottom: 4px;">Renouveler le domaine</h4>
                  <p style="font-size: 0.85rem; color: var(--color-text-muted);">Prolongez la durée d'enregistrement d'une année supplémentaire (gratuitement pour les forfaits standards).</p>
                </div>
                <button class="btn btn-secondary" id="renewDomainBtn">Renouveler (1 an)</button>
              </div>

              <div style="border: 1px solid #ffccd1; padding: 24px; border-radius: var(--radius-sm); background-color: rgba(210,31,60,0.02); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                <div>
                  <h4 style="color: var(--color-danger); margin-bottom: 4px;">Supprimer le domaine</h4>
                  <p style="font-size: 0.85rem; color: var(--color-text-muted);">Résiliez l'enregistrement du nom de domaine. Le domaine redeviendra immédiatement disponible pour le public.</p>
                </div>
                <button class="btn btn-danger" id="deleteDomainBtn">Résilier le domaine</button>
              </div>
            </div>

          </div>

          <!-- Empty Selection State (Visible when mgmtPanel is hidden) -->
          <div id="emptyPanel" style="background-color: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 48px; text-align: center; box-shadow: var(--shadow-sm);">
            <div style="max-width: 400px; margin: 0 auto;">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted); margin-bottom: 20px;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
              <h3 style="margin-bottom: 8px;">Aucun domaine sélectionné</h3>
              <p style="color: var(--color-text-muted); font-size: 0.95rem;">Veuillez cliquer sur l'un de vos noms de domaine dans la colonne latérale pour configurer la zone DNS ou changer les serveurs.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .tab-btn {
    border-bottom: 3px solid transparent !important;
  }
  .tab-btn.active {
    border-bottom: 3px solid var(--color-accent) !important;
    color: var(--color-accent) !important;
  }
</style>

<script>
  // State variables
  let currentSession: any = null;
  let currentUserIndex: number = -1;
  let allUsers: any[] = [];
  let selectedDomainIndex: number = -1;

  // DOM elements
  const dbLoading = document.getElementById('dashboardLoading');
  const dbContent = document.getElementById('dashboardContent');
  const domainListUl = document.getElementById('domainListUl');
  const noDomainsMsg = document.getElementById('noDomainsMsg');
  
  const mgmtPanel = document.getElementById('mgmtPanel');
  const emptyPanel = document.getElementById('emptyPanel');
  
  const mgmtDomainName = document.getElementById('mgmtDomainName');
  const mgmtRegDate = document.getElementById('mgmtRegDate');
  const mgmtExpDate = document.getElementById('mgmtExpDate');
  const mgmtPriceBadge = document.getElementById('mgmtPriceBadge');

  // Tab contents
  const dnsTabContent = document.getElementById('dnsTabContent');
  const nsTabContent = document.getElementById('nsTabContent');
  const redirTabContent = document.getElementById('redirTabContent');
  const actionsTabContent = document.getElementById('actionsTabContent');

  // Load and check session
  function checkSession() {
    const sessionStr = localStorage.getItem('point_session');
    if (!sessionStr) {
      window.location.href = '/connexion';
      return;
    }

    currentSession = JSON.parse(sessionStr);
    allUsers = JSON.parse(localStorage.getItem('point_users') || '[]');
    currentUserIndex = allUsers.findIndex((u: any) => u.email === currentSession.email);

    if (currentUserIndex === -1) {
      localStorage.removeItem('point_session');
      window.location.href = '/connexion';
      return;
    }

    if (dbLoading) dbLoading.style.display = 'none';
    if (dbContent) dbContent.style.display = 'block';

    renderDomainList();
  }

  function saveAllUsers() {
    localStorage.setItem('point_users', JSON.stringify(allUsers));
  }

  function getDomains() {
    return allUsers[currentUserIndex].domains || [];
  }

  // Render Sidebar Domain List
  function renderDomainList() {
    if (!domainListUl || !noDomainsMsg) return;
    domainListUl.innerHTML = '';

    const domains = getDomains();

    if (domains.length === 0) {
      noDomainsMsg.style.display = 'block';
      if (mgmtPanel) mgmtPanel.style.display = 'none';
      if (emptyPanel) emptyPanel.style.display = 'block';
      return;
    }

    noDomainsMsg.style.display = 'none';

    domains.forEach((dom: any, idx: number) => {
      const li = document.createElement('li');
      const isSelected = selectedDomainIndex === idx;
      
      li.innerHTML = `
        <button class="btn btn-outline" style="width: 100%; text-align: left; justify-content: flex-start; border-color: ${isSelected ? 'var(--color-accent)' : 'var(--color-border)'}; background-color: ${isSelected ? 'var(--color-light)' : 'transparent'}; font-weight: 600;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px; color: ${isSelected ? 'var(--color-accent)' : 'var(--color-text-muted)'};"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          ${dom.name}
        </button>
      `;

      li.querySelector('button')?.addEventListener('click', () => {
        selectDomain(idx);
      });

      domainListUl.appendChild(li);
    });
  }

  // Select Domain and load management panel
  function selectDomain(idx: number) {
    selectedDomainIndex = idx;
    renderDomainList();

    const dom = getDomains()[idx];
    if (!dom) return;

    if (emptyPanel) emptyPanel.style.display = 'none';
    if (mgmtPanel) mgmtPanel.style.display = 'block';

    if (mgmtDomainName) mgmtDomainName.textContent = dom.name;
    if (mgmtRegDate) mgmtRegDate.textContent = dom.registeredAt;
    if (mgmtExpDate) mgmtExpDate.textContent = dom.expiresAt;
    if (mgmtPriceBadge) {
      mgmtPriceBadge.textContent = dom.price;
      if (dom.price === 'Gratuit') {
        mgmtPriceBadge.className = 'badge badge-success';
      } else {
        mgmtPriceBadge.className = 'badge badge-info';
      }
    }

    // Default Tab
    switchTab('dns');
    loadDnsRecords();
    loadNsServers();
    loadRedirection();
  }

  // TAB SWITCHING LOGIC
  const tabDnsBtn = document.getElementById('tabDnsBtn');
  const tabNsBtn = document.getElementById('tabNsBtn');
  const tabRedirBtn = document.getElementById('tabRedirBtn');
  const tabActionsBtn = document.getElementById('tabActionsBtn');

  function switchTab(tab: string) {
    const tabs = [
      { id: 'dns', btn: tabDnsBtn, content: dnsTabContent },
      { id: 'ns', btn: tabNsBtn, content: nsTabContent },
      { id: 'redir', btn: tabRedirBtn, content: redirTabContent },
      { id: 'actions', btn: tabActionsBtn, content: actionsTabContent }
    ];

    tabs.forEach(t => {
      if (t.id === tab) {
        t.btn?.classList.add('active');
        t.btn?.style.setProperty('border-bottom', '3px solid var(--color-accent)');
        t.btn?.style.setProperty('color', 'var(--color-accent)');
        if (t.content) t.content.style.display = 'block';
      } else {
        t.btn?.classList.remove('active');
        t.btn?.style.setProperty('border-bottom', '3px solid transparent');
        t.btn?.style.setProperty('color', 'var(--color-text-muted)');
        if (t.content) t.content.style.display = 'none';
      }
    });

    // Hide any success alerts
    const alerts = ['nsSuccess', 'redirSuccess'];
    alerts.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
  }

  tabDnsBtn?.addEventListener('click', () => switchTab('dns'));
  tabNsBtn?.addEventListener('click', () => switchTab('ns'));
  tabRedirBtn?.addEventListener('click', () => switchTab('redir'));
  tabActionsBtn?.addEventListener('click', () => switchTab('actions'));

  // TAB 1: DNS RECORDS
  const dnsRecordsTbody = document.getElementById('dnsRecordsTbody');
  const addDnsRecordForm = document.getElementById('addDnsRecordForm') as HTMLFormElement;

  function loadDnsRecords() {
    if (!dnsRecordsTbody) return;
    dnsRecordsTbody.innerHTML = '';

    const dom = getDomains()[selectedDomainIndex];
    if (!dom || !dom.records) return;

    dom.records.forEach((rec: any, recIdx: number) => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td style="font-weight: 600; color: var(--color-accent);">${rec.type}</td>
        <td>${rec.name}</td>
        <td style="font-family: monospace; font-size: 0.9rem;">${rec.value}</td>
        <td>${rec.ttl}</td>
        <td>
          <button class="btn btn-outline btn-sm delete-rec-btn" style="color: var(--color-danger); border-color: var(--color-border);">Supprimer</button>
        </td>
      `;

      tr.querySelector('.delete-rec-btn')?.addEventListener('click', () => {
        deleteDnsRecord(recIdx);
      });

      dnsRecordsTbody.appendChild(tr);
    });
  }

  function deleteDnsRecord(recIdx: number) {
    if (confirm("Supprimer cet enregistrement DNS ?")) {
      allUsers[currentUserIndex].domains[selectedDomainIndex].records.splice(recIdx, 1);
      saveAllUsers();
      loadDnsRecords();
    }
  }

  if (addDnsRecordForm) {
    addDnsRecordForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const dnsType = (document.getElementById('dnsType') as HTMLSelectElement).value;
      const dnsName = (document.getElementById('dnsName') as HTMLInputElement).value.trim();
      const dnsValue = (document.getElementById('dnsValue') as HTMLInputElement).value.trim();
      const dnsTtl = (document.getElementById('dnsTtl') as HTMLInputElement).value;

      const newRecord = {
        type: dnsType,
        name: dnsName,
        value: dnsValue,
        ttl: dnsTtl
      };

      allUsers[currentUserIndex].domains[selectedDomainIndex].records.push(newRecord);
      saveAllUsers();
      loadDnsRecords();
      addDnsRecordForm.reset();
    });
  }

  // TAB 2: NAMESERVERS
  const nsForm = document.getElementById('nsForm') as HTMLFormElement;
  const ns1Input = document.getElementById('ns1Input') as HTMLInputElement;
  const ns2Input = document.getElementById('ns2Input') as HTMLInputElement;
  const nsSuccess = document.getElementById('nsSuccess');

  function loadNsServers() {
    const dom = getDomains()[selectedDomainIndex];
    if (!dom || !dom.ns) return;

    if (ns1Input) ns1Input.value = dom.ns[0] || 'ns1.point.ml';
    if (ns2Input) ns2Input.value = dom.ns[1] || 'ns2.point.ml';
  }

  if (nsForm) {
    nsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!ns1Input || !ns2Input) return;

      allUsers[currentUserIndex].domains[selectedDomainIndex].ns = [
        ns1Input.value.trim(),
        ns2Input.value.trim()
      ];
      saveAllUsers();
      if (nsSuccess) nsSuccess.style.display = 'block';
    });
  }

  // TAB 3: REDIRECTION WEB
  const redirForm = document.getElementById('redirForm') as HTMLFormElement;
  const redirActive = document.getElementById('redirActive') as HTMLInputElement;
  const redirUrl = document.getElementById('redirUrl') as HTMLInputElement;
  const redirSuccess = document.getElementById('redirSuccess');

  function loadRedirection() {
    const dom = getDomains()[selectedDomainIndex];
    if (!dom) return;

    const r = dom.redirection || { active: false, url: "" };
    if (redirActive) redirActive.checked = r.active;
    if (redirUrl) redirUrl.value = r.url;
  }

  if (redirForm) {
    redirForm.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!redirActive || !redirUrl) return;

      allUsers[currentUserIndex].domains[selectedDomainIndex].redirection = {
        active: redirActive.checked,
        url: redirActive.checked ? redirUrl.value.trim() : ""
      };
      saveAllUsers();
      if (redirSuccess) redirSuccess.style.display = 'block';
    });
  }

  // TAB 4: ADMINISTRATION ACTIONS
  const renewDomainBtn = document.getElementById('renewDomainBtn');
  const deleteDomainBtn = document.getElementById('deleteDomainBtn');

  if (renewDomainBtn) {
    renewDomainBtn.addEventListener('click', () => {
      const dom = getDomains()[selectedDomainIndex];
      if (!dom) return;

      // Extract current expiry parts (DD/MM/YYYY)
      const parts = dom.expiresAt.split('/');
      if (parts.length === 3) {
        const currentExp = new Date(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0]));
        const newExp = new Date(currentExp.setFullYear(currentExp.getFullYear() + 1));
        
        allUsers[currentUserIndex].domains[selectedDomainIndex].expiresAt = newExp.toLocaleDateString('fr-FR');
        saveAllUsers();
        selectDomain(selectedDomainIndex);
        alert("Félicitations ! L'enregistrement de votre domaine a été prolongé d'une année supplémentaire.");
      }
    });
  }

  if (deleteDomainBtn) {
    deleteDomainBtn.addEventListener('click', () => {
      const dom = getDomains()[selectedDomainIndex];
      if (!dom) return;

      if (confirm(`ATTENTION : Êtes-vous absolument sûr de vouloir résilier le domaine ${dom.name} ? Cette action est définitive et la zone DNS sera désactivée immédiatement.`)) {
        allUsers[currentUserIndex].domains.splice(selectedDomainIndex, 1);
        saveAllUsers();
        selectedDomainIndex = -1;
        checkSession();
      }
    });
  }

  // Init
  checkSession();
</script>
